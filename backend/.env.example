# Copy to .env and fill in. .env is gitignored.

# production | development  (development surfaces error detail in responses)
APP_ENV=development

# ---- Database (MariaDB) ----
DB_NAME=clockwork
DB_USER=clockwork
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too
# Host port mapped to MariaDB (container always listens on 3306)
DB_PORT=3306

# ---- API ----
# Host port mapped to the PHP/Apache container
API_PORT=8080

# ---- Sign in with Apple ----
# Your app's identifier — must equal the `aud` claim in Apple identity tokens.
# (App bundle ID for native SIWA, or the Services ID for web.)
APPLE_CLIENT_ID=com.example.clockwork
