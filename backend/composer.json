{
    "name": "clockwork/backend",
    "description": "Clockwork Life backend REST API (PHP 8.3+ / MariaDB)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "ext-json": "*",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Clockwork\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Clockwork\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "serve": "php -S 0.0.0.0:8080 -t public",
        "test": "phpunit --testsuite unit",
        "test:e2e": "bash scripts/run-e2e.sh"
    }
}
